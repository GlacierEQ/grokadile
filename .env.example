# ─────────────────────────────────────────────────────────────────────────────
# Grokadile — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
MODEL_VERSION=v1.0.0
RUN_ID=run-001
ENV=production
API_SECRET_KEY=change-me-to-a-random-secret

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@oXXXXX.ingest.sentry.io/XXXXXXX
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-org-slug

# ── Vercel ────────────────────────────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── MotherDuck ────────────────────────────────────────────────────────────────
MOTHERDUCK_TOKEN=

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=

# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TRAINING_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Sheets ─────────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com"}
GSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ── Supermemory.ai ────────────────────────────────────────────────────────────
SUPERMEMORY_API_KEY=

# ── ClickUp ───────────────────────────────────────────────────────────────────
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLICKUP_LIST_ID=
