# ─── Stealth Team Environment Variables ─────────────────────────────────────
# Copy to .env and fill in your values. Never commit .env to git.

# Model
CKPT_PATH=./checkpoints/
TOKENIZER_PATH=./tokenizer.model
MAX_LEN=512
TEMPERATURE=0.7

# DeepSpeed
WORLD_SIZE=1
USE_DEEPSPEED=1

# Sentry
SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# MotherDuck
MOTHERDUCK_TOKEN=your-motherduck-token

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENV=us-east-1

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Notion
NOTION_TOKEN=secret_your-notion-integration-token
NOTION_DATABASE_ID=your-run-log-db-id

# Google
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/google-sa.json
GOOGLE_SHEET_ID=your-sheet-id

# Supermemory
SUPERMEMORY_API_KEY=your-supermemory-api-key

# ClickUp
CLICKUP_API_KEY=your-clickup-api-key
CLICKUP_LIST_ID=your-list-id
